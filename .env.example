# Astro build / dev — Directus backend URL.
# In production, point this at the public URL of the CMS.
DIRECTUS_URL=http://192.168.178.29:8085

# Static token of the content-bot Directus user, used by
# scripts/add-product.mjs (the /add-products workflow). Create/read on
# producten, categorieen, galerij and files only. Generate with
# `openssl rand -hex 32` and run deploy/cms/build-schema.mjs with
# CONTENT_TOKEN set to the same value.
DIRECTUS_CONTENT_TOKEN=
