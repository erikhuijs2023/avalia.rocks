---
/**
 * BaseLayout — example Astro layout that wires the whole library together:
 * loads fonts + stylesheets, renders the navbar/footer, mounts global overlays,
 * and imports the interactions script ONCE.
 *
 * Copy this into your project's src/layouts/ and adjust nav/footer/site data
 * (ideally fed from the Directus "Site Instellingen" singleton).
 */
import '../styles/tokens.css';
import '../styles/components.css';
// interactions (age gate, lightbox, toast) ship as a static asset from /public
// so they only execute in the browser, not during SSR. Tag is rendered below.

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import GlobalOverlays from '../components/GlobalOverlays.astro';

export interface Props {
  title?: string;
  active?: string;
}
const { title = 'Avalia', active } = Astro.props;

// In production, fetch these from Directus once and pass down.
const site = {
  brand: 'Avalia',
  links: [
    { label: 'Products', href: '/products', key: 'products' },
    { label: 'Updates', href: '/updates', key: 'updates' },
    { label: 'About', href: '/about', key: 'about' },
    { label: 'Contact', href: '/contact', key: 'contact' }
  ],
  social: { marketplace: '#', instagram: '#', bluesky: '#' }
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lobster&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <GlobalOverlays brand={site.brand} />
  <Navbar brand={site.brand} links={site.links} active={active} social={site.social} />

  <main>
    <slot />
  </main>

  <Footer brand={site.brand} links={site.links} social={site.social} />

  <script is:inline src="/avalia-ui.js" defer></script>
</body>
</html>
