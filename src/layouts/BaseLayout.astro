---
/**
 * BaseLayout — example Astro layout that wires the whole library together:
 * loads fonts + stylesheets, renders the navbar/footer, mounts global overlays,
 * and imports the interactions script ONCE.
 *
 * Copy this into your project's src/layouts/ and adjust nav/footer/site data
 * (ideally fed from the Directus "Site Instellingen" singleton).
 */
import '../styles/tokens.css';
import '../styles/components.css';
// interactions (age gate, lightbox, toast) ship as a static asset from /public
// so they only execute in the browser, not during SSR. Tag is rendered below.

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import GlobalOverlays from '../components/GlobalOverlays.astro';
import { getSite } from '../lib/directus';

export interface Props {
  title?: string;
  active?: string;
}
const { title = 'Avalia', active } = Astro.props;

// Brand + tagline come from the Directus `site_instellingen` singleton so
// you can rename the site from the CMS without a code change. Nav links and
// social URLs are stable enough to live here.
const settings = await getSite();
const site = {
  brand: settings.site_naam,
  tagline: settings.tagline,
  links: [
    { label: 'Products', href: '/products', key: 'products' },
    { label: 'Updates', href: '/updates', key: 'updates' },
    { label: 'About', href: '/about', key: 'about' },
    { label: 'Contact', href: '/contact', key: 'contact' }
  ],
  social: settings.social_links
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {/* ?v= busts the browser's dedicated favicon cache (which ignores normal
      cache headers). Bump it whenever the icon artwork changes. */}
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png?v=2" />
  <link rel="alternate icon" href="/favicon.ico?v=2" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lobster&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  {/* Umami analytics — privacy-friendly, no cookies. Self-hosted on
      the mini-pc behind the Unraid SWAG reverse proxy at
      stats.avalia.rocks. Skipped on `npm run dev` so local testing
      doesn't pollute the dashboard. */}
  {import.meta.env.PROD && (
    <script
      defer
      src="https://stats.avalia.rocks/avalia-stats.js"
      data-website-id="dd7f431a-9c20-47e4-9a07-43348c2d5096"></script>
  )}
</head>
<body>
  <GlobalOverlays brand={site.brand} />
  <Navbar brand={site.brand} links={site.links} active={active} social={site.social} />

  <main>
    <slot />
  </main>

  <Footer brand={site.brand} tagline={site.tagline} links={site.links} social={site.social} />

  <script is:inline src="/avalia-ui.js" defer></script>
</body>
</html>
