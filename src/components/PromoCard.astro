---
/**
 * PromoCard — full-bleed hero slide. Maps to the Directus `Promos` content type.
 * Use as the homepage hero or a campaign banner.
 *
 * <PromoCard
 *   title={promo.titel}
 *   description={promo.beschrijving}
 *   image={directusAsset(promo.afbeelding)}
 *   ctaText={promo.cta_tekst}
 *   ctaUrl={promo.cta_url}
 *   featured
 *   minHeight="80vh"   // full-viewport hero
 * />
 */
import Button from './Button.astro';
import Badge from './Badge.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  alt?: string;
  /** CSS object-position value (e.g. "50% 30%") — typically piped through
   *  from the Directus focal point. Falls back to centre when omitted. */
  focal?: string;
  ctaText?: string;
  ctaUrl?: string;
  ctaExternal?: boolean;
  featured?: boolean;        // show "Featured" badge
  minHeight?: string;        // e.g. "420px" (default) or "80vh" for hero
  class?: string;
}
const {
  title, description, image, alt = '', focal,
  ctaText, ctaUrl, ctaExternal = false,
  featured = false, minHeight = '420px', class: cls = ''
} = Astro.props;
const objectPosition = focal || 'center';
---
<article class={['promo-card', cls].filter(Boolean).join(' ')} style={`min-height:${minHeight}`}>
  {image
    ? <div class="media" style={`background-image:url(${image});background-size:cover;background-position:${objectPosition}`}>
        <img src={image} alt={alt || title} style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:${objectPosition}`} loading="eager" />
      </div>
    : <div class="media"></div>}
  <div class="promo-overlay"></div>
  <div class="promo-content">
    {featured && <Badge variant="featured" class="" />}
    <h2 style="margin-top:14px">{title}</h2>
    {description && <p>{description}</p>}
    {ctaText && ctaUrl && (
      <Button variant="primary" size="lg" href={ctaUrl} external={ctaExternal}>{ctaText}</Button>
    )}
    <slot />
  </div>
</article>
