---
/**
 * Field — a labelled form control. One component covers input / textarea / select.
 *
 * <Field label="Name" name="name" placeholder="Your SL name" />
 * <Field label="Message" name="message" as="textarea" />
 * <Field label="Subject" name="subject" as="select"
 *        options={['General','Collaboration','Support','Other']} />
 * <Field label="Email" name="email" error="Enter a valid email." />
 */
export interface Props {
  label?: string;
  name?: string;
  as?: 'input' | 'textarea' | 'select';
  type?: string;            // for input: text, email, …
  placeholder?: string;
  value?: string;
  options?: (string | { label: string; value: string })[];
  required?: boolean;
  disabled?: boolean;
  error?: string;
  class?: string;
}
const {
  label, name, as = 'input', type = 'text', placeholder, value = '',
  options = [], required = false, disabled = false, error, class: cls = ''
} = Astro.props;

const inputClass = ['input', error ? 'is-error' : '', cls].filter(Boolean).join(' ');
const norm = options.map((o) => (typeof o === 'string' ? { label: o, value: o } : o));
---
<div class="field">
  {label && <label class="field-label" for={name}>{label}</label>}

  {as === 'textarea' && (
    <textarea id={name} name={name} class={['textarea', error ? 'is-error' : '', cls].filter(Boolean).join(' ')}
      placeholder={placeholder} required={required} disabled={disabled}>{value}</textarea>
  )}

  {as === 'select' && (
    <div class="av-cselect" data-cselect>
      <select id={name} name={name} class="av-cselect-native" required={required} disabled={disabled} tabindex="-1" aria-hidden="true">
        {norm.map((o) => <option value={o.value} selected={o.value === value}>{o.label}</option>)}
      </select>
      <button type="button" class="select av-cselect-trigger" data-cselect-trigger
        aria-haspopup="listbox" aria-expanded="false" disabled={disabled}>
        <span data-cselect-label>{(norm.find((o) => o.value === value) || norm[0])?.label || ''}</span>
      </button>
      <ul class="av-cselect-panel" role="listbox" data-cselect-panel hidden>
        {norm.map((o) => (
          <li>
            <button type="button" role="option" data-cselect-option data-value={o.value}
              class={o.value === value ? 'is-active' : ''}
              aria-selected={o.value === value ? 'true' : 'false'}>{o.label}</button>
          </li>
        ))}
      </ul>
    </div>
  )}

  {as === 'input' && (
    <input id={name} name={name} class={inputClass} type={type}
      placeholder={placeholder} value={value} required={required} disabled={disabled} />
  )}

  {error && <span class="field-error">{error}</span>}
</div>

<script>
  // Idempotent custom select: skin .av-cselect over a real <select> so form
  // submit still works, but the open panel uses our dark palette (Chrome no
  // longer respects color-scheme for option panels).
  function initCustomSelects() {
    document.querySelectorAll('[data-cselect]').forEach((root) => {
      if ((root as any)._bound) return;
      (root as any)._bound = true;

      const native = root.querySelector('select.av-cselect-native') as HTMLSelectElement;
      const trigger = root.querySelector('[data-cselect-trigger]') as HTMLButtonElement;
      const panel = root.querySelector('[data-cselect-panel]') as HTMLElement;
      const label = root.querySelector('[data-cselect-label]') as HTMLElement;
      if (!native || !trigger || !panel || !label) return;

      const close = () => {
        panel.setAttribute('hidden', '');
        trigger.setAttribute('aria-expanded', 'false');
        root.classList.remove('is-open');
      };
      const open = () => {
        panel.removeAttribute('hidden');
        trigger.setAttribute('aria-expanded', 'true');
        root.classList.add('is-open');
      };

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        if (root.classList.contains('is-open')) close(); else open();
      });

      // Keep the skin in sync with the underlying <select>. Covers both an
      // option click and an external reset: set native.value + fire 'change'
      // and the trigger label + active option follow.
      const sync = () => {
        const opt = panel.querySelector<HTMLButtonElement>(
          `[data-cselect-option][data-value="${CSS.escape(native.value)}"]`
        );
        if (!opt) return;
        label.textContent = opt.textContent || '';
        panel.querySelectorAll('[data-cselect-option]').forEach((o) => {
          const on = o === opt;
          o.classList.toggle('is-active', on);
          o.setAttribute('aria-selected', on ? 'true' : 'false');
        });
      };
      native.addEventListener('change', sync);

      panel.querySelectorAll<HTMLButtonElement>('[data-cselect-option]').forEach((opt) => {
        opt.addEventListener('click', () => {
          native.value = opt.dataset.value || '';
          native.dispatchEvent(new Event('change', { bubbles: true }));
          close();
        });
      });

      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && root.classList.contains('is-open')) {
          close();
          trigger.focus();
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCustomSelects);
  } else {
    initCustomSelects();
  }
  document.addEventListener('astro:page-load', initCustomSelects);
</script>
