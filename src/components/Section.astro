---
/**
 * Section — a max-width content section with optional header.
 * Wraps children in <Container>. Add `reveal` to fade content in on scroll.
 *
 * <Section eyebrow="Shop" title="Featured products" viewAllHref="/products" viewAllLabel="View all →">
 *   <div class="av-grid av-grid-3"> … </div>
 * </Section>
 */
export interface Props {
  title?: string;
  eyebrow?: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  tight?: boolean;          // smaller vertical padding
  reveal?: boolean;         // scroll-reveal the inner content
  id?: string;
  class?: string;
}
const {
  title, eyebrow, viewAllHref, viewAllLabel = 'View all →',
  tight = false, reveal = false, id, class: cls = ''
} = Astro.props;

const sectionClass = ['av-section', tight ? 'av-section--tight' : '', cls].filter(Boolean).join(' ');
const headerClass = ['av-section-header', viewAllHref ? 'av-row' : ''].filter(Boolean).join(' ');
---
<section id={id} class={sectionClass}>
  <div class="av-container">
    {(title || eyebrow) && (
      <div class={headerClass}>
        <div>
          {eyebrow && <div class="av-eyebrow">{eyebrow}</div>}
          {title && <h2>{title}</h2>}
          <div class="av-divider"></div>
        </div>
        {viewAllHref && <a class="btn btn-ghost link-accent" href={viewAllHref}><span>{viewAllLabel}</span></a>}
      </div>
    )}
    <div class={reveal ? 'av-reveal' : ''}>
      <slot />
    </div>
  </div>
</section>
