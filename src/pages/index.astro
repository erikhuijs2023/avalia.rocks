---
/**
 * Homepage — composed per the blueprint wireframe.
 * Data comes from Directus (src/lib/directus.ts).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import PromoCard from '../components/PromoCard.astro';
import TopTask from '../components/TopTask.astro';
import ProductCard from '../components/ProductCard.astro';
import UpdateCard from '../components/UpdateCard.astro';
import { activePromo, featuredProducts, publishedUpdates } from '../lib/directus';

const [hero, featured, updates] = await Promise.all([
  activePromo(),
  featuredProducts('avas-lewd'),   // HDM featured live on /hdm, not here
  publishedUpdates()
]);
const latest = updates.slice(0, 2);
---
<BaseLayout title="Avalia — Second Life Digital Fashion" active="home">

  {hero && (
    <PromoCard
      title={hero.titel}
      description={hero.beschrijving}
      image={hero.afbeelding}
      focal={hero.afbeelding_focal}
      ctaText={hero.cta_tekst}
      ctaUrl={hero.cta_url}
      featured
      minHeight="86vh"
    />
  )}

  <Section tight>
    <div class="av-grid av-grid-3">
      <TopTask icon="box" title="Products" href="/products">Browse the full collection with live previews.</TopTask>
      <TopTask icon="message" title="Support" href="/contact">Questions about a purchase or a HUD? I'm here.</TopTask>
      <TopTask icon="sparkle" title="News" href="/updates">The latest drops, fixes and features.</TopTask>
    </div>
  </Section>

  {featured.length > 0 && (
    <Section eyebrow="Shop" title="Featured products" viewAllHref="/products?merk=avas-lewd" viewAllLabel="View all products →" reveal>
      <div class="av-grid av-grid-3">
        {featured.map((p) => (
          <ProductCard
            name={p.naam}
            href={`/products/${p.slug}`}
            category={p.categorie.naam}
            description={p.korte_beschrijving}
            image={p.afbeeldingen[0]}
            isNew={p.is_nieuw}
          />
        ))}
      </div>
    </Section>
  )}

  <Section eyebrow="News" title="Latest updates" viewAllHref="/updates" viewAllLabel="All updates →" reveal>
    <div class="av-grid av-grid-2">
      {latest.map((u) => (
        <UpdateCard
          title={u.titel}
          href={`/updates/${u.slug}`}
          date={u.publicatiedatum}
          excerpt={u.excerpt}
          image={u.afbeelding}
        />
      ))}
    </div>
  </Section>

</BaseLayout>
