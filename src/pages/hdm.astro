---
/**
 * /hdm — landing page for the HDM (Hugo's Design) sub-brand.
 * Text + gradient hero (reuses PromoCard's media/overlay via its slot) with a
 * bold "HDM" wordmark + an optional "Featured" spotlight. The full catalog
 * lives on /products?merk=hdm (the page links there) — no grid duplicated here.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import PromoCard from '../components/PromoCard.astro';
import ProductCard from '../components/ProductCard.astro';
import Button from '../components/Button.astro';
import { getProducten } from '../lib/directus';

const all = await getProducten();
const hdmFeatured = all.filter((p) => p.merk === 'hdm' && p.status === 'published' && p.is_featured);
---
<BaseLayout title="HDM — Hugo's Design × Avalia" active="hdm">

  <PromoCard minHeight="60vh" class="hdm-hero">
    <span class="hdm-eyebrow">Hugo's Design</span>
    <h1 class="hdm-wordmark text-accent">HDM</h1>
    <p class="hdm-tagline">
      Precision-cut latex &amp; frames — a Hugo's Design line, crafted in collaboration with Ava's Lewd.
    </p>
    <Button variant="primary" size="lg" href="/products?merk=hdm">Browse the collection</Button>
  </PromoCard>

  {hdmFeatured.length > 0 && (
    <Section eyebrow="Spotlight" title="Featured" reveal>
      <div class="av-grid av-grid-3">
        {hdmFeatured.map((p) => (
          <ProductCard
            name={p.naam}
            href={`/products/${p.slug}`}
            category={p.categorie.naam}
            description={p.korte_beschrijving}
            image={p.afbeeldingen[0]}
            isNew={p.is_nieuw}
          />
        ))}
      </div>
    </Section>
  )}

  <Section tight>
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
      <Button variant="secondary" size="lg" href="/products?merk=hdm">Shop all HDM</Button>
      <Button variant="ghost" size="lg" href="/contact?brand=HDM">HDM support</Button>
    </div>
  </Section>

</BaseLayout>
