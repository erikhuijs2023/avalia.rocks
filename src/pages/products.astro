---
/**
 * /products — overview grid with category / brand / collection filters.
 * Filtering is client-side: every published product is rendered with
 * data-category / data-merk / data-collectie, and the three dropdowns
 * combine with AND logic.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ProductCard from '../components/ProductCard.astro';
import Field from '../components/Field.astro';
import { getProducten, getCategorieen, getCollecties } from '../lib/directus';

const [allProducten, categorieen, collecties] = await Promise.all([
  getProducten(), getCategorieen(), getCollecties()
]);
const published = allProducten.filter((p) => p.status === 'published');

const categoryOptions = [
  { label: 'All categories', value: 'all' },
  ...categorieen.map((c) => ({ label: c.naam, value: c.slug }))
];
const brandOptions = [
  { label: 'All brands', value: 'all' },
  { label: "Ava's Lewd", value: 'avas-lewd' },
  { label: 'HDM', value: 'hdm' }
];
const collectionOptions = [
  { label: 'All collections', value: 'all' },
  ...collecties.map((c) => ({ label: c.naam, value: c.slug }))
];
---
<BaseLayout title="Products — Avalia" active="products">

  <Section eyebrow="Shop" title="All products">
    <p style="margin-top:-12px;color:var(--text-secondary);max-width:60ch">
      Latex wearables, HUDs, and accessories — handmade for Second Life. Filter by category, brand or collection.
    </p>

    <div class="product-filters">
      <Field as="select" label="Category" name="filter-category" options={categoryOptions} value="all" />
      <Field as="select" label="Brand" name="filter-merk" options={brandOptions} value="all" />
      <Field as="select" label="Collection" name="filter-collectie" options={collectionOptions} value="all" />
      <button type="button" id="filter-reset" class="filter-reset" aria-label="Clear all filters">
        Clear filters<span class="filter-reset-x" aria-hidden="true">×</span>
      </button>
    </div>

    <div class="av-grid av-grid-3" id="product-grid">
      {published.map((p) => (
        <div data-category={p.categorie.slug} data-merk={p.merk} data-collectie={p.collectie?.slug || ''}>
          <ProductCard
            name={p.naam}
            href={`/products/${p.slug}`}
            category={p.categorie.naam}
            description={p.korte_beschrijving}
            image={p.afbeeldingen[0]}
            isNew={p.is_nieuw}
          />
        </div>
      ))}
    </div>

    <p id="product-empty" style="display:none;margin-top:32px;color:var(--text-secondary);text-align:center">
      No products match these filters — try widening them.
    </p>
  </Section>

  <script is:inline>
    (function () {
      var grid = document.getElementById('product-grid');
      var empty = document.getElementById('product-empty');
      if (!grid) return;
      var fCat = document.getElementById('filter-category');
      var fMerk = document.getElementById('filter-merk');
      var fCol = document.getElementById('filter-collectie');
      var reset = document.getElementById('filter-reset');
      var selects = [fCat, fMerk, fCol];
      function val(s) { return s && s.value ? s.value : 'all'; }
      function apply() {
        var c = val(fCat), m = val(fMerk), col = val(fCol), visible = 0;
        grid.querySelectorAll('[data-category]').forEach(function (el) {
          var show =
            (c === 'all' || el.getAttribute('data-category') === c) &&
            (m === 'all' || el.getAttribute('data-merk') === m) &&
            (col === 'all' || el.getAttribute('data-collectie') === col);
          el.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
        // Reveal the reset only when at least one filter is narrowed.
        if (reset) reset.classList.toggle('is-shown', c !== 'all' || m !== 'all' || col !== 'all');
      }
      selects.forEach(function (s) { if (s) s.addEventListener('change', apply); });
      if (reset) reset.addEventListener('click', function () {
        selects.forEach(function (s) {
          if (s && s.value !== 'all') {
            s.value = 'all';
            s.dispatchEvent(new Event('change', { bubbles: true }));  // skin + grid follow
          }
        });
      });

      // Pre-apply filters from URL params, e.g. /products?merk=hdm (the HDM
      // landing links here) or ?merk=avas-lewd (the homepage). Also supports
      // ?category= and ?collectie=. Updates the native <select> + the skinned
      // dropdown directly so it's independent of the custom-select init timing.
      (function preApply() {
        try {
          var sp = new URLSearchParams(location.search);
          var map = { category: fCat, merk: fMerk, collectie: fCol };
          var applied = false;
          Object.keys(map).forEach(function (key) {
            var want = sp.get(key), sel = map[key];
            if (!want || !sel) return;
            var match = Array.prototype.slice.call(sel.options).filter(function (o) {
              return o.value.toLowerCase() === want.toLowerCase();
            })[0];
            if (!match) return;
            sel.value = match.value;
            var root = sel.closest('[data-cselect]');
            if (root) {
              var label = root.querySelector('[data-cselect-label]');
              if (label) label.textContent = match.textContent || match.value;
              root.querySelectorAll('[data-cselect-option]').forEach(function (o) {
                var on = o.getAttribute('data-value') === match.value;
                o.classList.toggle('is-active', on);
                o.setAttribute('aria-selected', on ? 'true' : 'false');
              });
            }
            applied = true;
          });
          if (applied) apply();
        } catch (e) {}
      })();
    })();
  </script>

</BaseLayout>
