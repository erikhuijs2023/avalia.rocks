---
/**
 * /products — overview grid with category filter pills.
 * Filtering is client-side (CategoryFilter emits `filter:change`).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ProductCard from '../components/ProductCard.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import { getProducten, getCategorieen } from '../lib/directus';

const [allProducten, categorieen] = await Promise.all([getProducten(), getCategorieen()]);
const filterOptions = [
  { label: 'All', value: 'all' },
  ...categorieen.map((c) => ({ label: c.naam, value: c.slug }))
];
const published = allProducten.filter((p) => p.status === 'published');
---
<BaseLayout title="Products — Avalia" active="products">

  <Section eyebrow="Shop" title="All products">
    <p style="margin-top:-12px;color:var(--text-secondary);max-width:60ch">
      Latex wearables, HUDs, and accessories — handmade for Second Life. Use the filter to narrow by category.
    </p>

    <div style="margin:32px 0 28px">
      <CategoryFilter options={filterOptions} active="all" scrollable />
    </div>

    <div class="av-grid av-grid-3" id="product-grid">
      {published.map((p) => (
        <div data-category={p.categorie.slug}>
          <ProductCard
            name={p.naam}
            href={`/products/${p.slug}`}
            category={p.categorie.naam}
            description={p.korte_beschrijving}
            image={p.afbeeldingen[0]}
            isNew={p.is_nieuw}
          />
        </div>
      ))}
    </div>

    <p id="product-empty" style="display:none;margin-top:32px;color:var(--text-secondary);text-align:center">
      Nothing in this category yet — check back soon.
    </p>
  </Section>

  <script is:inline>
    (function () {
      var grid = document.getElementById('product-grid');
      var empty = document.getElementById('product-empty');
      if (!grid) return;
      function apply(value) {
        var visible = 0;
        grid.querySelectorAll('[data-category]').forEach(function (el) {
          var show = value === 'all' || el.getAttribute('data-category') === value;
          el.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
      }
      document.addEventListener('filter:change', function (e) {
        apply((e.detail && e.detail.value) || 'all');
      });
    })();
  </script>

</BaseLayout>
