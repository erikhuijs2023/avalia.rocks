# Umami self-hosted analytics — copy to .env (mode 600) next to
# docker-compose.yml on the mini-pc, then `docker compose up -d`.
# Never commit the real .env.

# 32-byte hex strings. Generate with:
#   openssl rand -hex 32
APP_SECRET=
DB_PASSWORD=

# Filename(s) the tracker script is served as. Helps avoid adblock
# filters that block "umami*". MUST include the .js suffix in Umami
# 3.x — the middleware does literal pathname matching. Comma-sep list.
TRACKER_SCRIPT_NAME=avalia-stats.js
