# Avalia site/mailer secrets — copy to .env next to docker-compose.yml on the
# mini-pc, then `docker compose up -d`. Never commit the real .env.

# Gmail SMTP (use an App Password, NOT your account password).
# See https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=avalia.ferrentino@gmail.com
SMTP_PASS=

# Destination + visible From header.
MAIL_TO=avalia.ferrentino@gmail.com
MAIL_FROM=Avalia Contact <avalia.ferrentino@gmail.com>

# Optional: max contact-form submits per IP per hour (default 5).
RATE_PER_HOUR=5

# ─── avalia-builder (auto-rebuild on Directus webhook) ──────────────────────
# Shared secret. Directus sends this in the `X-Avalia-Token` header; the
# builder rejects requests that don't match. Generate one with:
#   openssl rand -hex 32
HOOK_TOKEN=

# Git repo to build from. Override to a private fork via SSH if needed.
REPO_URL=https://github.com/erikhuijs2023/avalia.rocks.git
GIT_BRANCH=main

# Directus URL the build hits during `npm run build`. Default is the local
# Directus on this same mini-pc; change only if you move the CMS.
DIRECTUS_URL=http://192.168.178.29:8085

# Debounce window (ms) — collapses bursts of saves into one build. 0 disables.
DEBOUNCE_MS=10000

# ─── support tickets ─────────────────────────────────────────────────────────
# Static token of the "mailer-bot" Directus user (create-only on tickets).
# Generate with `openssl rand -hex 32`, then run deploy/cms/build-schema.mjs
# with TICKETS_TOKEN set so the bot user gets the same token. When set, every
# contact-form submission is stored as a ticket in Directus next to the mail.
TICKETS_TOKEN=
