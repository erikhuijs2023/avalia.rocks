# Generate the real values on the host with:
#   openssl rand -hex 32   (for KEY, SECRET, DB_PASSWORD)
#   openssl rand -base64 24 | tr -d '=+/' | head -c 24   (admin password)
# Copy to .env next to docker-compose.yml; never commit the real file.

# Bind to the LAN IP so other devices on the network can reach the admin UI.
# Use 127.0.0.1 to keep it localhost-only.
BIND_IP=192.168.178.29
HOST_PORT=8085

# 32-byte hex secrets — required by Directus.
DIRECTUS_KEY=
DIRECTUS_SECRET=

# Bootstrap admin user (only used the first time the container starts).
ADMIN_EMAIL=e.huijs@gmail.com
ADMIN_PASSWORD=

# Postgres password.
DB_PASSWORD=

# Public URL Directus advertises in API responses and admin links.
PUBLIC_URL=http://192.168.178.29:8085

# CORS origin for the Astro frontend (comma-separated for multiple).
CORS_ORIGIN=http://localhost:4321,http://192.168.178.29:8084
